generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  school_admin
  teacher
  parent
  student
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  firstName    String?
  lastName     String?
  avatar       String?
  email        String   @unique
  passwordHash String
  role         Role
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  children       Child[]           @relation("StudentUser")
  parentChildren ParentChildLink[] @relation("ParentUser")
  notifications  Notification[]
  payments       Payment[]
  subscriptions  Subscription[]
  auditLogs      AuditLog[]

  // New relations
  teacherClasses    Class[]            @relation("TeacherClasses")
  teacherCourses    Course[]           @relation("TeacherCourses")
  enrollments       Enrollment[]       @relation("StudentEnrollments")
  courseEnrollments CourseEnrollment[] @relation("StudentCourseEnrollments")
  submissions       Submission[]       @relation("StudentSubmissions")
  attendance        Attendance[]       @relation("StudentAttendance")
  lessonAccessLogs  LessonAccessLog[]
  
  isActive       Boolean      @default(false)
  invitation     Invitation?
}

model Invitation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  status    InvitationStatus @default(pending)
  invitedBy String   @db.ObjectId
  createdAt DateTime @default(now())
}

enum InvitationStatus {
  pending
  accepted
  expired
}

model EmailLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  to        String
  subject   String
  type      String   
  status    String   
  error     String?
  sentAt    DateTime?
  createdAt DateTime @default(now())
}

model Child {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation("StudentUser", fields: [userId], references: [id])
  userId    String   @db.ObjectId
  firstName String
  lastName  String
  birthDate DateTime

  parents        ParentChildLink[]
  progress       Progress[]
  attempts       Attempt[]
  recommendations Recommendation[]
  gamification    GamificationProfile?
}

model ParentChildLink {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  parent   User   @relation("ParentUser", fields: [parentId], references: [id])
  parentId String @db.ObjectId
  child    Child  @relation(fields: [childId], references: [id])
  childId  String @db.ObjectId
}

model Subject {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  name    String  @unique
  topics  Topic[]
  lessons Lesson[]
  progress Progress[]
  classes  Class[]
  courses  Course[]
}

model Topic {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  subjectId String   @db.ObjectId
  lessons   Lesson[]
}

model Lesson {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subject     Subject    @relation(fields: [subjectId], references: [id])
  subjectId   String     @db.ObjectId
  
  unit        Unit?      @relation(fields: [unitId], references: [id])
  unitId      String?    @db.ObjectId
  
  lessonType  String     @default("note") // video | pdf | note
  fileUrl     String?
  duration    Int?       // in seconds
  
  content     String
  exercises   Exercise[]
  accessLogs  LessonAccessLog[]
  topic       Topic?     @relation(fields: [topicId], references: [id])
  topicId     String?    @db.ObjectId
}

model Exercise {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  lesson      Lesson     @relation(fields: [lessonId], references: [id])
  lessonId    String     @db.ObjectId
  prompt      String
  difficulty  Float
  maxScore    Float
  attempts    Attempt[]
}

model Progress {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  child     Child    @relation(fields: [childId], references: [id])
  childId   String   @db.ObjectId
  subject   Subject  @relation(fields: [subjectId], references: [id])
  subjectId String   @db.ObjectId
  percent   Float
  updatedAt DateTime @updatedAt
}

model Attempt {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  child       Child     @relation(fields: [childId], references: [id])
  childId     String    @db.ObjectId
  exercise    Exercise  @relation(fields: [exerciseId], references: [id])
  exerciseId  String    @db.ObjectId
  correct     Boolean
  rawScore    Float
  responseMs  Int
  createdAt   DateTime  @default(now())
}

model Recommendation {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  child      Child    @relation(fields: [childId], references: [id])
  childId    String   @db.ObjectId
  exerciseId String
  rationale  String
  createdAt  DateTime @default(now())
}

model GamificationProfile {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  student   Child    @relation(fields: [studentId], references: [id])
  studentId String   @unique @db.ObjectId
  xp        Int      @default(0)
  level     Int      @default(1)
  badges    GamificationBadge[]
}

model GamificationBadge {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  profile   GamificationProfile @relation(fields: [profileId], references: [id])
  profileId String              @db.ObjectId
  studentId String
  code      String
  awardedAt DateTime
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Payment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @db.ObjectId
  amountCents   Int
  currency      String
  status        String
  providerRef   String
  createdAt     DateTime @default(now())
}

model Subscription {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  userId       String   @db.ObjectId
  plan         String
  status       String
  currentPeriodEnd DateTime
  createdAt    DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?  @db.ObjectId
  action    String
  details   String
  createdAt DateTime @default(now())
}

// New Models for School Management

model Class {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  teacher     User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  teacherId   String   @db.ObjectId
  subject     Subject  @relation(fields: [subjectId], references: [id])
  subjectId   String   @db.ObjectId
  courseId    String?  @db.ObjectId
  course      Course?  @relation(fields: [courseId], references: [id])
  enrollments Enrollment[]
  assignments Assignment[]
  attendance  Attendance[]
  schedules   ClassSchedule[]
  schedule    DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClassSchedule {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  class      Class    @relation(fields: [classId], references: [id])
  classId    String   @db.ObjectId
  dayOfWeek  Int      // 0=Sun 1=Mon … 6=Sat
  startTime  String   // "HH:MM" 24h
  endTime    String   // "HH:MM" 24h
  room       String?
  recurrence String   @default("weekly") // weekly | biweekly | daily
  validFrom  DateTime
  validUntil DateTime?
  createdAt  DateTime @default(now())
}


model Enrollment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  student   User     @relation("StudentEnrollments", fields: [studentId], references: [id])
  studentId String   @db.ObjectId
  class     Class    @relation(fields: [classId], references: [id])
  classId   String   @db.ObjectId
  createdAt DateTime @default(now())
}

model Assignment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  dueDate     DateTime
  class       Class?   @relation(fields: [classId], references: [id])
  classId     String?  @db.ObjectId
  unit        Unit?    @relation(fields: [unitId], references: [id])
  unitId      String?  @db.ObjectId
  rubric      String?  // JSON string of rubric criteria
  maxScore    Float?
  submissions Submission[]
  createdAt   DateTime @default(now())
}

model Submission {
   id           String   @id @default(auto()) @map("_id") @db.ObjectId
   assignment   Assignment @relation(fields: [assignmentId], references: [id])
   assignmentId String   @db.ObjectId
   student      User     @relation("StudentSubmissions", fields: [studentId], references: [id])
   studentId    String   @db.ObjectId
   content      String?
   fileUrl      String?
   score        Float?
   feedback     String?
   rubricScores Json?
   status       String   @default("pending")  // pending | graded
   createdAt    DateTime @default(now())
}

model Attendance {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  class       Class?   @relation(fields: [classId], references: [id])
  classId     String?  @db.ObjectId
  unit        Unit?    @relation(fields: [unitId], references: [id])
  unitId      String?  @db.ObjectId
  student     User     @relation("StudentAttendance", fields: [studentId], references: [id])
  studentId   String   @db.ObjectId
  status      String   @default("present")  // present | absent | late | excused | sick | on_leave
  note        String?
  
  // Verification details
  latitude    Float?
  longitude   Float?
  deviceId    String?
  ipAddress   String?
  
  date        DateTime
  markedAt    DateTime?
  submittedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum CalendarEventType {
  class_session
  assignment_due
  quiz
  examination
  school_event
  holiday
  personal_reminder
  meeting
}

model CalendarEvent {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String?
  type         CalendarEventType @default(class_session)
  startDate    DateTime
  endDate      DateTime?
  allDay       Boolean           @default(false)
  classId      String?           @db.ObjectId
  assignmentId String?           @db.ObjectId
  createdBy    String            @db.ObjectId
  visibility   String            @default("personal")  // personal | class | school
  color        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Course {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  title             String
  description       String?
  category          String?
  learningObjectives String[]
  status            String   @default("draft") // draft | published
  
  teacher           User     @relation("TeacherCourses", fields: [teacherId], references: [id])
  teacherId         String   @db.ObjectId
  
  subject           Subject  @relation(fields: [subjectId], references: [id])
  subjectId         String   @db.ObjectId
  
  modules           Module[]
  enrollments       CourseEnrollment[]
  classes           Class[]
  prerequisites     CoursePrerequisite[] @relation("CourseToPrerequisite")
  requiredBy        CoursePrerequisite[] @relation("PrerequisiteToCourse")
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Module {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  order       Int
  course      Course   @relation(fields: [courseId], references: [id])
  courseId    String   @db.ObjectId
  units       Unit[]
  isLocked    Boolean  @default(false)
}

model Unit {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  order       Int
  module      Module   @relation(fields: [moduleId], references: [id])
  moduleId    String   @db.ObjectId
  lessons     Lesson[]
  assignments Assignment[]
  attendance  Attendance[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CourseEnrollment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  student   User     @relation("StudentCourseEnrollments", fields: [studentId], references: [id])
  studentId String   @db.ObjectId
  course    Course   @relation(fields: [courseId], references: [id])
  courseId  String   @db.ObjectId
  progress  Float    @default(0)
  status    String   @default("active") // active | completed | dropped
  createdAt DateTime @default(now())
}

model CoursePrerequisite {
  id                   String @id @default(auto()) @map("_id") @db.ObjectId
  course               Course @relation("CourseToPrerequisite", fields: [courseId], references: [id])
  courseId             String @db.ObjectId
  prerequisiteCourse   Course @relation("PrerequisiteToCourse", fields: [prerequisiteCourseId], references: [id])
  prerequisiteCourseId String @db.ObjectId
}

model LessonAccessLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  student   User     @relation(fields: [studentId], references: [id])
  studentId String   @db.ObjectId
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  lessonId  String   @db.ObjectId
  accessedAt DateTime @default(now())
  durationMs Int      @default(0)
}

model Reminder {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @db.ObjectId
  title        String
  description  String?
  dueDate      DateTime
  priority     String    @default("medium")   // low | medium | high
  repeat       String    @default("none")      // none | daily | weekly | monthly
  channel      String    @default("in_app")    // in_app | email | both
  isDone       Boolean   @default(false)
  snoozedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
