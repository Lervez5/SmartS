{
    "name": "smartsprout-workspace",
    "private": true,
    "scripts": {
        "dev": "concurrently \"pnpm --filter @smartsprout/backend dev\" \"pnpm --filter @smartsprout/frontend-kids dev\" \"cd ai_engine && ./.venv/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 5000 --reload\"",
        "db:push": "pnpm --filter @smartsprout/backend exec prisma db push",
        "backend:generate": "pnpm --filter @smartsprout/backend exec prisma generate"
    },
    "dependencies": {
        "concurrently": "^9.2.1"
    },
    "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
